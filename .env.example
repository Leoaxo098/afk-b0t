# ============================================================
#  .env - Central Credentials & Secrets
# ============================================================

# 1. Discord Bot Authentication
# (Get this from Discord Developer Portal -> Bot -> Reset Token)
DISCORD_TOKEN=YOUR_BOT_TOKEN_HERE

# 2. Application IDs
# (Found in Developer Portal -> General Information -> Application ID)
DISCORD_CLIENT_ID=YOUR_CLIENT_ID_HERE

# 3. Server Specific IDs
# (Right-click your Server Name in Discord -> Copy Server ID)
DISCORD_GUILD_ID=YOUR_SERVER_ID_HERE

# 4. Roles and Channels
# (Right-click the Role or Channel in Discord -> Copy ID)
DISCORD_ADMIN_ROLE_ID=YOUR_ADMIN_ROLE_ID_HERE
DISCORD_ADMIN_CHANNEL_ID=YOUR_TEXT_CHANNEL_ID_FOR_ALERTS_HERE

# 5. Fallback Webhook (Optional - if your original code still uses it)
WEBHOOK_URL=https://discord.com/api/webhooks/xxxx/xxxx